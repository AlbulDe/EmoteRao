-- [ 6. LOGIC INTEGRATION ]
local function playEmote(id)
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum then
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://" .. tostring(id)
        local track = hum:LoadAnimation(anim)
        track:Play()
    end
end

-- I-load ang emotes (Gamit ang source sa Emotes.txt mo)
task.spawn(function()
    local success, result = pcall(function()
        return game:HttpGet("https://raw.githubusercontent.com/7yd7/sniper-Emote/refs/heads/test/EmoteSniper.json")
    end)
    
    if success then
        local data = HttpService:JSONDecode(result).data
        for _, v in pairs(data) do
            local btn = Instance.new("TextButton")
            btn.Name = v.name
            btn.Text = v.name
            btn.Parent = EmoteGrid
            btn.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
            btn.TextColor3 = Color3.fromRGB(200, 200, 200)
            btn.Font = Enum.Font.GothamMedium
            btn.TextSize = 10
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
            
            btn.MouseButton1Click:Connect(function() playEmote(v.id) end)
        end
    end
end)

-- Search Function
SearchBar:GetPropertyChangedSignal("Text"):Connect(function()
    local input = SearchBar.Text:lower()
    for _, btn in pairs(EmoteGrid:GetChildren()) do
        if btn:IsA("TextButton") then
            btn.Visible = (input == "" or btn.Name:lower():find(input))
        end
    end
end)

-- [ 7. TOGGLE & DRAG FIX ]
local function toggle()
    MainPanel.Visible = not MainPanel.Visible
end

MenuBtn.MouseButton1Click:Connect(toggle)
CloseX.MouseButton1Click:Connect(function() MainPanel.Visible = false end)

-- Smooth Mobile Drag
local dragging, dragStart, startPos
MenuBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging, dragStart, startPos = true, input.Position, MenuBtn.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MenuBtn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function() dragging = false end)
